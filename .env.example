# Backend
BACKEND_PORT=8080
FRONTEND_URL=https://localhost:5173,https://自分のIPアドレス:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=kaleido
DB_PASSWORD=kaleido
DB_NAME=kaleido_scan

# LLM
# AI_PROVIDER: "gemini"（ローカル開発）または "bedrock"（本番Lambda）
AI_PROVIDER=bedrock
GEMINI_API_KEY=

# Bedrock（AI_PROVIDER=bedrock のときのみ使用）
# Lambda上ではIAMロールで自動認証するため AWS_ACCESS_KEY_ID 等の設定は不要
# ローカルでBedrockを使う場合は aws configure またはここで設定する
AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL_ID: 未設定の場合は us.amazon.nova-pro-v1:0 を使用
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# AI呼び出しをスキップしてスタブを返す（true: スタブ強制 / false or 未設定: 通常AI呼び出し）
USE_STUB=false
