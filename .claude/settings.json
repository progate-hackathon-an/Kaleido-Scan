{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/hiruge/Project/Kaleido-Scan/.claude/hooks/format.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm /*)",
      "Bash(rm -rf /*)",
      "Bash(mv /*)",
      "Read(*.env)",
      "Read(*/.env)",
      "Read(*.key)",
      "Read(*.pem)"
    ]
  }
}
